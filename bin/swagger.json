        "type": "object",
        "properties": {
          "id": { "type": "number" },
          "attemptNumber": { "type": "number" },
          "userId": { "type": "string" },
          "quizId": { "type": "number" },
          "status": { "type": "string" },
          "score": { "type": "number" },
          "totalQuestions": { "type": "number" },
